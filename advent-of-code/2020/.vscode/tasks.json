{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "test",
      "type": "shell",
      "command": "deno test --fail-fast '${file}'",
      "group": {
        "kind": "test",
        "isDefault": true
      },
      "problemMatcher": []
    },
    {
      "label": "run",
      "type": "shell",
      "command": "deno run --quiet --allow-read '${file}'",
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": []
    },
    {
      "label": "lint",
      "type": "shell",
      "command": "deno lint '${file}'",
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": []
    },
    {
      "label": "fmt",
      "type": "shell",
      "command": "deno fmt '${file}'",
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": []
    },
    {
      "type": "deno",
      "command": "test",
      "problemMatcher": ["$deno-test"],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "label": "deno: test"
    }
  ]
}
